{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Scuro protocol manifest",
  "type": "object",
  "required": [
    "contracts",
    "enum_labels",
    "proof_inputs",
    "local_defaults",
    "deployment_output_labels"
  ],
  "properties": {
    "contracts": {
      "type": "array"
    },
    "enum_labels": {
      "type": "object"
    },
    "proof_inputs": {
      "type": "object"
    },
    "local_defaults": {
      "type": "object"
    },
    "deployment_output_labels": {
      "type": "object"
    }
  }
}