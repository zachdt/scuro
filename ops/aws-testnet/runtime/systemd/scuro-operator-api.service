[Unit]
Description=Scuro private operator API
After=network-online.target scuro-anvil.service
Wants=network-online.target scuro-anvil.service

[Service]
Type=simple
EnvironmentFile=-/etc/scuro-testnet/scuro.env
EnvironmentFile=-/etc/scuro-testnet/bootstrap.env
EnvironmentFile=-/etc/scuro-testnet/runtime.env
WorkingDirectory=/opt/scuro-testnet/current
ExecStart=/opt/scuro-testnet/tools/bin/bun run /opt/scuro-testnet/current/ops/aws-testnet/src/operator.ts
Restart=always
RestartSec=3
StandardOutput=append:/var/log/scuro-testnet/operator-api.log
StandardError=append:/var/log/scuro-testnet/operator-api.log

[Install]
WantedBy=multi-user.target
