SCURO_REPO_ROOT=/opt/scuro-testnet/current
SCURO_SERVICE_ROOT=/opt/scuro-testnet/current/ops/testnet
SCURO_STATE_DIR=/var/lib/scuro-testnet
SCURO_OPERATOR_HOST=127.0.0.1
SCURO_OPERATOR_PORT=8787
SCURO_RPC_URL=http://127.0.0.1:8545
SCURO_CHAIN_ID=31337
SCURO_ENABLE_PUBLIC_RPC=1
SCURO_CLOUDFLARE_RPC_HOSTNAME=rpc-testnet.example.com
SCURO_PUBLIC_RPC_URL=https://rpc-testnet.example.com
SCURO_ORIGIN_CERT_PATH=/etc/scuro-testnet/tls/origin.pem
SCURO_ORIGIN_KEY_PATH=/etc/scuro-testnet/tls/origin.key
